# ---------------------------------------------------------------------------
# Tourist Safety — environment configuration
# Copy to `.env` and adjust. Never commit a real `.env`.
# ---------------------------------------------------------------------------

# Tooling: set to true if your network uses a custom root CA (corporate proxy
# / antivirus TLS inspection) so uv/pip use the OS certificate store.
UV_NATIVE_TLS=true
# Set to 1 only if building the app Docker image fails with TLS cert errors
# behind such a proxy (allows insecure hosts during pip install). 0 = secure.
UV_INSECURE=0

# App
APP_NAME=tourist-safety
ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Postgres + PostGIS
# When running the app locally (hybrid mode) use localhost.
# When running the app inside docker-compose, use the service name `postgres`.
POSTGRES_USER=tourist
POSTGRES_PASSWORD=tourist
POSTGRES_DB=tourist_safety
POSTGRES_HOST=localhost
# Host port mapped to the container's 5432. If 5432 is taken/reserved on your
# machine (common on Windows due to WinNAT reserved ranges), use 5433.
POSTGRES_PORT=5433

# Redis (use `redis` as host when running app inside compose)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ---------------------------------------------------------------------------
# LLM provider — provider-agnostic. Defaults to Groq (OpenAI-compatible API).
# Used from M4 onward. Leave key blank to force dry-run/mock mode.
# ---------------------------------------------------------------------------
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_DRY_RUN=true

# Data retention (DPDP) — days after which raw location pings expire
LOCATION_RETENTION_DAYS=30
